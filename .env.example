# Server
PORT=5000
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_db_password_here
DB_NAME=preop_db

# Auth
# Generate a long random secret, e.g. `node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"`
JWT_SECRET=replace_me_with_a_long_random_string
JWT_EXPIRES_IN=8h

# Client (CORS origin)
CLIENT_URL=http://localhost:5173
